{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "A client or business account managed by the agency.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the store." },
        "ownerId": { "type": "string", "description": "The UID of the agency owner who created the store." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information including roles and store assignment.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "employee"] },
        "storeId": { "type": "string", "description": "The ID of the store this user belongs to." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "CampaignReport": {
      "title": "Campaign Report",
      "description": "Weekly performance data for a specific campaign.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "campaignDate": { "type": "string", "format": "date" },
        "campaignName": { "type": "string" },
        "purchases": { "type": "number" },
        "costPerPurchase": { "type": "number" },
        "confirmed": { "type": "number" },
        "canceled": { "type": "number" },
        "pending": { "type": "number" },
        "totalSpend": { "type": "number" },
        "netOrders": { "type": "number" },
        "cancellationRate": { "type": "number" },
        "confirmationRate": { "type": "number" },
        "performanceScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "employeeId", "campaignDate", "campaignName", "purchases", "costPerPurchase"]
    }
  },
  "firestore": {
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Collection of client stores."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles and roles."
    },
    "/reports/{reportId}": {
      "schema": "CampaignReport",
      "description": "Collection of weekly campaign reports."
    }
  }
}
